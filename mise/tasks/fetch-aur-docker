#!/usr/bin/env bash
# Runs INSIDE an archlinux:latest container (CI path). Builds the AUR
# greeter packages and copies them to the mounted /out directory.
# The host's mise task fetch-aur is the local-dev equivalent.

set -euo pipefail

OUT_DIR="/out"
mkdir -p "${OUT_DIR}"

# Install build deps
pacman -Syu --noconfirm --needed base-devel git

# Create a non-root builder (makepkg refuses root)
useradd -m -G wheel builder
echo 'builder ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers

# Build order matters: shikai-theme installs into nody-greeter's theme dir.
PKGS=("nody-greeter" "shikai-theme")
BUILD_DIR="/tmp/aur-build"
mkdir -p "${BUILD_DIR}"
chown builder:builder "${BUILD_DIR}"

for pkg in "${PKGS[@]}"; do
    echo "==> Building ${pkg} from the AUR..."
    sudo -u builder git clone --depth 1 "https://aur.archlinux.org/${pkg}.git" "${BUILD_DIR}/${pkg}"
    # Strip debug packages — they bloat the repo past GitHub's 100MB limit
    # and serve no purpose in a binary package mirror.
    sudo -u builder bash -c "cd '${BUILD_DIR}/${pkg}' && makepkg -s --needed --noconfirm --noconfirm"

    rm -f "${OUT_DIR}/${pkg}-"*.pkg.tar.zst
    # Copy only non-debug packages under 50MB (GitHub's recommended max).
    # Larger packages (nody-greeter is 100MB+ with bundled node) can't go
    # through git — they get built into the Tenebrux ISO's local repo instead.
    for f in "${BUILD_DIR}/${pkg}/"*.pkg.tar.zst; do
        base="$(basename "$f")"
        if [[ "$base" == *-debug-* ]]; then
            echo "    Skipping debug package: $base"
            continue
        fi
        size_mb=$(du -m "$f" | cut -f1)
        if [ "$size_mb" -gt 50 ]; then
            echo "    WARNING: $base is ${size_mb}MB — exceeds 50MB limit, skipping"
            echo "    (large packages get built into the Tenebrux ISO local repo, not naur)"
            continue
        fi
        cp "$f" "${OUT_DIR}/"
    done

    # Install so the next package can depend against it.
    pacman -U --noconfirm --needed "${BUILD_DIR}/${pkg}/"*.pkg.tar.zst || true
done

echo "==> AUR packages built into ${OUT_DIR}"
