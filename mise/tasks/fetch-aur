#!/usr/bin/env bash
#MISE description="Build AUR packages (nody-greeter, shikai-theme) into x86_64/"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(realpath "${SCRIPT_DIR}/../../x86_64")"
mkdir -p "${REPO_DIR}"

FORCE="${1:-}"

# Build order matters: shikai-theme installs into nody-greeter's theme dir.
PKGS=("nody-greeter" "shikai-theme")

# Skip if both are already present
have_all=1
for pkg in "${PKGS[@]}"; do
    compgen -G "${REPO_DIR}/${pkg}-*.pkg.tar.zst" >/dev/null 2>&1 || have_all=0
done
if [ "${have_all}" -eq 1 ] && [ "${FORCE}" != "--force" ]; then
    echo "==> AUR packages already built, skipping (use --force to rebuild)"
    exit 0
fi

command -v makepkg >/dev/null || { echo "ERROR: makepkg not found (install base-devel)"; exit 1; }
[ "$(id -u)" -ne 0 ] || { echo "ERROR: do not run as root; makepkg refuses root"; exit 1; }

BUILD_DIR="$(mktemp -d)"
trap 'rm -rf "${BUILD_DIR}"' EXIT

for pkg in "${PKGS[@]}"; do
    echo "==> Building ${pkg} from the AUR..."
    git clone --depth 1 "https://aur.archlinux.org/${pkg}.git" "${BUILD_DIR}/${pkg}"
    # -s syncs deps; --needed avoids reinstall. AUR-on-AUR deps (shikai → nody)
    # are satisfied by installing the prior build.
    (cd "${BUILD_DIR}/${pkg}" && makepkg -s --needed --noconfirm)

    rm -f "${REPO_DIR}/${pkg}-"*.pkg.tar.zst
    cp "${BUILD_DIR}/${pkg}/"*.pkg.tar.zst "${REPO_DIR}/"

    # Install locally so the next package can depend against it.
    sudo pacman -U --noconfirm --needed "${BUILD_DIR}/${pkg}/"*.pkg.tar.zst || true
done

echo "==> AUR packages built."
