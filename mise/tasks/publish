#!/usr/bin/env bash
#MISE description="Push x86_64/ to the gh-pages branch (live site updates)"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="${SCRIPT_DIR}/../.."
PKG_DIR="$(realpath "${ROOT}/x86_64")"

if [ ! -f "${PKG_DIR}/naur.db" ]; then
    echo "ERROR: No repo database found. Run 'mise build' first."
    exit 1
fi

echo "==> Publishing to gh-pages..."

cd "${ROOT}"

# In CI, git remote is read-only (no credentials). Inject the GITHUB_TOKEN
# so the orphan-branch push can authenticate. Locally (no GITHUB_TOKEN set),
# fall back to the existing remote (which has ssh or personal token creds).
if [ -n "${GITHUB_TOKEN:-}" ]; then
    REMOTE_URL="https://x-access-token:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY:-FynxLabs/naur}.git"
else
    REMOTE_URL=$(git remote get-url origin)
fi

# Fresh clone into a temp dir so the working tree stays clean.
TMP_CLONE="$(mktemp -d)"
trap 'rm -rf "${TMP_CLONE}"' EXIT

# Try to clone gh-pages; if it doesn't exist, init a fresh orphan branch.
if git clone --branch gh-pages --depth 1 "${REMOTE_URL}" "${TMP_CLONE}" 2>/dev/null; then
    echo "    Cloned existing gh-pages branch"
else
    echo "    gh-pages branch not found, creating orphan branch..."
    cd "${TMP_CLONE}"
    git init
    git remote add origin "${REMOTE_URL}"
    git checkout --orphan gh-pages
fi

cd "${TMP_CLONE}"

# Replace the x86_64 dir with the freshly built one
rm -rf x86_64
mkdir -p x86_64
cp -r "${PKG_DIR}/." x86_64/

git add -A
git -c user.name="FynxLabs Bot" \
    -c user.email="bot@fynxlabs.dev" \
    commit -m "repo: update packages ($(date -u +%Y-%m-%dT%H:%M:%SZ))

$(ls x86_64/*.pkg.tar.zst | wc -l) packages"

git push origin gh-pages
echo "==> Published. Live at https://fynxlabs.github.io/naur/"
