#!/usr/bin/env bash
#MISE description="Push x86_64/ to the gh-pages branch (live site updates)"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="${SCRIPT_DIR}/../.."
PKG_DIR="$(realpath "${ROOT}/x86_64")"

if [ ! -f "${PKG_DIR}/naur.db" ]; then
    echo "ERROR: No repo database found. Run 'mise build' first."
    exit 1
fi

echo "==> Publishing to gh-pages..."

# Use a temp clone so we never touch the working tree's git state
TMP_CLONE="$(mktemp -d)"
trap 'rm -rf "${TMP_CLONE}"' EXIT

cd "${ROOT}"
git clone --branch gh-pages --depth 1 . "${TMP_CLONE}" 2>/dev/null || {
    # gh-pages branch doesn't exist yet — create it
    echo "    gh-pages branch not found, creating..."
    cd "${TMP_CLONE}"
    git checkout --orphan gh-pages
    git rm -rf . 2>/dev/null || true
}

cd "${TMP_CLONE}"

# Replace the x86_64 dir with the freshly built one
rm -rf x86_64
mkdir -p x86_64
cp -r "${PKG_DIR}/." x86_64/

git add -A
git -c user.name="FynxLabs Bot" \
    -c user.email="bot@fynxlabs.dev" \
    commit -m "repo: update packages ($(date -u +%Y-%m-%dT%H:%M:%SZ))

$(ls x86_64/*.pkg.tar.zst | wc -l) packages"

git push origin gh-pages
echo "==> Published. Live at https://fynxlabs.github.io/naur/"
