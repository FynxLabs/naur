#!/usr/bin/env bash
#MISE description="Download FynxLabs release packages (dusk, umbra, ember, rwr) into x86_64/"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="${SCRIPT_DIR}/../../x86_64"
mkdir -p "${REPO_DIR}"

FORCE="${1:-}"

# ── Helper: find the latest release asset via the public REST API ───────────
# Uses curl + jq (no gh CLI, no GITHUB_TOKEN needed for public repos).
# Returns the browser_download_url of the asset matching the glob pattern.
find_asset_url() {
    local repo="$1" pattern="$2"

    # Try latest stable release first, then fall back to all releases.
    # The API endpoint /releases/latest only returns non-prerelease tags.
    local releases_json
    releases_json=$(curl -fsSL "https://api.github.com/repos/${repo}/releases?per_page=10" 2>/dev/null || \
                    curl -fsSL "https://api.github.com/repos/${repo}/releases" 2>/dev/null || \
                    echo '[]')

    # Find the first release with an asset matching the pattern.
    # Pattern uses shell glob syntax (* matches anything).
    echo "${releases_json}" | jq -r --arg pat "${pattern}" '
        .[].assets[] | select(.name | test($pat | gsub("[*]"; ".*") | "^" + . + "$")) | .browser_download_url
    ' | head -1
}

# ── Helper: download and fix pkgver ─────────────────────────────────────────
download_release() {
    local repo="$1"
    local pattern="$2"
    local pkgname="$3"

    echo "==> ${pkgname}: fetching from ${repo}..."

    # Skip if already present (unless --force)
    if [ -z "${FORCE}" ] && compgen -G "${REPO_DIR}/${pkgname}-*.pkg.tar.zst" >/dev/null 2>&1; then
        echo "    Already present, skipping (use --force to re-download)"
        return 0
    fi

    local asset_url
    asset_url=$(find_asset_url "${repo}" "${pattern}")
    if [ -z "${asset_url}" ]; then
        echo "    WARNING: No release asset matching '${pattern}' found in ${repo}"
        echo "    (the package may not have a release yet — skipping)"
        return 0
    fi

    echo "    Downloading: ${asset_url}"

    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf ${tmpdir}" RETURN

    local filename
    filename=$(basename "${asset_url}")
    curl -fsSL -o "${tmpdir}/${filename}" "${asset_url}"

    local downloaded="${tmpdir}/${filename}"
    if [ ! -f "${downloaded}" ]; then
        echo "ERROR: Download failed for ${pkgname}"
        return 1
    fi

    # Fix nfpm-style pkgver (dashes break pacman DB parsing)
    local pkgver
    pkgver=$(tar --zstd -xOf "${downloaded}" .PKGINFO 2>/dev/null | awk -F' = ' '/^pkgver/{print $2}')
    if [ -z "${pkgver}" ]; then
        echo "ERROR: Failed to read pkgver from ${downloaded}"
        return 1
    fi

    # Only fix if pkgver contains a dash (nfpm edge-xxx-1 style)
    if [[ "${pkgver}" == *-* ]]; then
        local pkgrel="${pkgver##*-}"
        local pkgver_only="${pkgver%-*}"
        local pkgver_clean="${pkgver_only//-/.}"
        local pkgver_full="${pkgver_clean}-${pkgrel}"

        echo "    Rewriting pkgver: ${pkgver} -> ${pkgver_full}"

        local workdir="${tmpdir}/fix"
        mkdir -p "${workdir}"
        bsdtar -xf "${downloaded}" -C "${workdir}"
        sed -i "s|^pkgver = .*|pkgver = ${pkgver_full}|" "${workdir}/.PKGINFO"

        local out="${REPO_DIR}/${pkgname}-${pkgver_full}-x86_64.pkg.tar.zst"
        rm -f "${REPO_DIR}/${pkgname}-"*.pkg.tar.zst

        local payload=()
        for entry in "${workdir}"/*; do
            [ -e "$entry" ] || continue
            payload+=("$(basename "$entry")")
        done
        (cd "${workdir}" && bsdtar --zstd -cf "${out}" .PKGINFO .MTREE "${payload[@]}")
    else
        rm -f "${REPO_DIR}/${pkgname}-"*.pkg.tar.zst
        cp "${downloaded}" "${REPO_DIR}/"
    fi

    echo "    Stored: $(ls "${REPO_DIR}/${pkgname}-"*.pkg.tar.zst | head -1 | xargs basename)"
}

# ── Download FynxLabs packages ──────────────────────────────────────────────
download_release "FynxLabs/dusk"  "dusk_*_linux_amd64.pkg.tar.zst"  "dusk"
download_release "FynxLabs/umbra" "umbra_*_linux_amd64.pkg.tar.zst" "umbra"
download_release "FynxLabs/ember" "ember_*_linux_amd64.pkg.tar.zst" "ember"
download_release "FynxLabs/rwr"   "rwr_*_linux_amd64.pkg.tar.zst"   "rwr"

echo "==> FynxLabs packages fetched."
